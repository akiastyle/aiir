#!/usr/bin/env bash
set -euo pipefail

ROOT="/var/www/aiir/server/scripts"
cmd="${1:-}" || true

usage() {
  cat >&2 <<'USAGE'
usage:
  /var/www/aiir/server/scripts/aiir <command> [args]

official commands:
  up       zero-conf bootstrap runtime/project
  deploy   AI-first deploy project/runtime/policy/web
  chat     operational AI chat entrypoint
  down     stop runtime

support commands:
  doctor   runtime diagnostics
  verify   run consolidated verification pack
  optimize optimize a project policy/env
  ui       scaffold UI preset for a project
  ingest   ingest source project into AIIR-operable assets
  convert  legacy alias of ingest
  parity   run logic+visual parity check
  bench    run open-repo benchmark (quick/full)
  oaiir    execute OAIIR web IR into runtime web output
  contract run AIIR contract test pack
  clean    clean generated/runtime artifacts
  audit    verify AI-first/AIIR operating rules
  automate enable periodic automation (systemd/cron)
USAGE
}

case "$cmd" in
  up)
    shift
    exec "${ROOT}/aiir-up.sh" "$@" ;;
  deploy)
    shift
    exec "${ROOT}/aiir-deploy.sh" "$@" ;;
  chat)
    shift
    exec "${ROOT}/aiir-chat.sh" "$@" ;;
  down)
    shift
    exec "${ROOT}/aiir-down.sh" "$@" ;;
  doctor)
    shift
    exec "${ROOT}/aiir-doctor.sh" "$@" ;;
  verify)
    shift
    exec "${ROOT}/aiir-verify.sh" "$@" ;;
  optimize)
    shift
    exec "${ROOT}/aiir-optimize-project.sh" "$@" ;;
  ui)
    shift
    exec "${ROOT}/aiir-ui-scaffold.sh" "$@" ;;
  ingest)
    shift
    exec "${ROOT}/aiir-ingest-project.sh" "$@" ;;
  convert)
    shift
    exec "${ROOT}/aiir-ingest-project.sh" "$@" ;;
  parity)
    shift
    exec "${ROOT}/aiir-parity-check.sh" "$@" ;;
  bench)
    shift
    exec "${ROOT}/aiir-bench.sh" "$@" ;;
  oaiir)
    shift
    exec "${ROOT}/aiir-oaiir-exec.sh" "$@" ;;
  contract)
    shift
    exec "${ROOT}/aiir-contract-test.sh" "$@" ;;
  clean)
    shift
    exec "${ROOT}/aiir-clean.sh" "$@" ;;
  audit)
    shift
    exec "${ROOT}/aiir-self-audit.sh" "$@" ;;
  automate)
    shift
    exec "${ROOT}/aiir-enable-automation.sh" "$@" ;;
  -h|--help|help|"")
    usage
    exit 0 ;;
  *)
    echo "unknown command: ${cmd}" >&2
    usage
    exit 1 ;;
esac
